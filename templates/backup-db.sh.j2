#!/usr/bin/env bash
set -euo pipefail

FILENAME="x-ui-$(date '+%Y-%m-%d_%H%M%S').db"
DB_PATH="{{ xui_control_db_path }}"
DEST="r2:{{ r2_bucket }}/{{ ansible_host }}"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $*"; }

log "Stopping {{ xui_control_xui_service }}"
systemctl stop {{ xui_control_xui_service }} || log "WARNING: failed to stop service"

cleanup() {
  log "Starting {{ xui_control_xui_service }}"
  systemctl start {{ xui_control_xui_service }} || { log "ERROR: failed to start service"; exit 1; }
}
trap cleanup EXIT

log "Uploading ${FILENAME} to ${DEST}"
rclone copyto "${DB_PATH}" "${DEST}/${FILENAME}" --config /root/.config/rclone/rclone.conf
log "Backup completed: ${FILENAME}"
